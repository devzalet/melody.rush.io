        body{
            margin:0;
            font-family: Arial, Helvetica, sans-serif;
            background:#f4f6f8;
            color:#222;
            line-height:1.7;
        }

        .wrapper{
            max-width:900px;
            margin:40px auto;
            padding:20px;
        }

        .container{
            background:white;
            border-radius:16px;
            padding:40px;
            box-shadow:0 8px 30px rgba(0,0,0,0.08);
        }

        h1{
            margin-top:0;
            color:#111;
            font-size:36px;
        }

        h2{
            margin-top:40px;
            color:#111;
            border-bottom:1px solid #ececec;
            padding-bottom:10px;
        }

        h3{
            margin-top:25px;
            color:#222;
        }

        p{
            margin:14px 0;
        }

        ul{
            padding-left:24px;
        }

        li{
            margin-bottom:8px;
        }

        .date{
