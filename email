            padding:20px;
            margin:25px 0;
        }

        .email{
            background:#f0f0f0;
            padding:3px 8px;
            border-radius:6px;
            word-break: break-word;
        }

        .steps{
            background:#fafafa;
            border:1px solid #e6e6e6;
            border-radius:10px;
            padding:16px 20px;
            margin:20px 0;
